# ppt-web 环境变量示例
# 复制成 .env 后填实际值；.env 已在 .gitignore 里
#   cp .env.example .env
#
# 启动前需先：docker 启动 MySQL + bash docker/ppt-runner/build.sh（见 README）

# ── DB（MySQL 8，必需）──────────────────────────────────────
# 先用 Docker 启动 MySQL（见 README 快速开始步骤 1），再填此 URL。
# 库字符集必须是 utf8mb4（不是 utf8，那个是 3 字节会截断 emoji）。
DB_URL=mysql+pymysql://pptweb:pptweb@127.0.0.1:3306/pptweb?charset=utf8mb4

# 连接池（仅 MySQL；SQLite 使用 StaticPool）
# 任务运行时会高频写 events 表；默认 pool 5+10 易在并发任务下耗尽。
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=60
DB_POOL_RECYCLE=3600

# ── 鉴权 ─────────────────────────────────────────────────────
# JWT 签名密钥。生产必设（设了之后旧 token 全部失效）。
# 不设的话每次重启进程会生成一个 ephemeral secret，登录态会丢。
#   openssl rand -hex 32
PPT_WEB_JWT_SECRET=013a2423f5a3fab64733d5de8ef48afa918264177736188aa6ee1dda202831cd

# ── 并发 ─────────────────────────────────────────────────────
# 全局最多同时跑几个生成任务（每个任务一个 docker 容器）。超过后 POST /api/jobs 返回 409。
MAX_CONCURRENT_JOBS=3

# ── Docker runner ───────────────────────────────────────────
# 每个 job 在临时容器内跑 claude（需先 build 镜像，见 README）。
DOCKER_RUNNER_IMAGE=ppt-runner:latest
DOCKER_RUNNER_NETWORK=ppt-isolated
DOCKER_RUNNER_MEMORY=4g
DOCKER_RUNNER_CPUS=2
# 单任务硬性墙钟上限（秒）：超过即停容器、标 failed、不退积分。
# 与 watchdog.stale_secs 不同：本项无差别，agent 在持续输出也会被杀。
# 复杂任务 / 多轮 resume 建议 ≥ 3600。Admin 后台可在线修改。
DOCKER_RUNNER_TIMEOUT_S=3600

# ── 八点确认（已禁用）────────────────────────────────────────
# 当前默认不确认：agent 直接采用推荐默认值并继续导出。
# 保留重试上限仅作兜底：如果 agent 仍主动停下，自动 resume 最多几轮。
SKIP_EIGHT_CONFIRM_MAX=3

# ── 显示时区 ─────────────────────────────────────────────────
# 前端时间展示使用的 IANA 时区，默认中国东八区。
DISPLAY_TIMEZONE=Asia/Shanghai
# VITE_DISPLAY_TIMEZONE=Asia/Shanghai  # 前端 build 时覆盖（可选）

# ── Admin ────────────────────────────────────────────────────
# 首次启动自动创建默认管理员：账号 admin / 密码 admin（已存在则不覆盖密码）。
# 生产环境请登录后立即改密。强制重置密码：
# PPT_WEB_RESET_ADMIN_PASSWORD=true

# ── Claude Code 环境变量（可选，也可在 Admin 后台设置）────────
# Admin UI 可覆盖以下变量并注入 Docker 容器：
# ANTHROPIC_BASE_URL, ANTHROPIC_MODEL, ANTHROPIC_DEFAULT_*_MODEL
# ANTHROPIC_AUTH_TOKEN, ANTHROPIC_API_KEY
# 以及 CLAUDE_* / HTTP_PROXY 等（见 Admin 设置页 allowlist）
