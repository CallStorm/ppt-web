# ppt-web 环境变量示例
# 复制成 .env 后填实际值；.env 已在 .gitignore 里
#   cp .env.example .env

# ── DB ───────────────────────────────────────────────────────
# 默认 sqlite 本地文件（jobs.db 在项目根）。要切 MySQL/Postgres 改这里：
#
#   MySQL 8:
#     DB_URL=mysql+pymysql://pptweb:pptweb@127.0.0.1:3306/pptweb?charset=utf8mb4
#   Postgres:
#     DB_URL=postgresql+psycopg2://user:pwd@host:5432/db
#
# 注意 MySQL 库必须用 utf8mb4 字符集（不是 utf8，那个是 3 字节会截断 emoji）。
# DB_URL=  # 留空 = sqlite:///./jobs.db

# ── 鉴权 ─────────────────────────────────────────────────────
# JWT 签名密钥。生产必设（设了之后旧 token 全部失效）。
# 不设的话每次重启进程会生成一个 ephemeral secret，登录态会丢。
#   openssl rand -hex 32
PPT_WEB_JWT_SECRET=

# ── 并发 ─────────────────────────────────────────────────────
# 全局最多同时跑几个生成任务（每个任务一个 docker 容器）。超过后 POST /api/jobs 返回 409。
MAX_CONCURRENT_JOBS=3

# ── Docker runner ───────────────────────────────────────────
# 开启后每个 job 起一个临时容器跑 claude；关闭则 host 上直接 Popen("claude")。
USE_DOCKER_RUNNER=false
DOCKER_RUNNER_IMAGE=ppt-runner:latest
DOCKER_RUNNER_NETWORK=ppt-isolated
DOCKER_RUNNER_MEMORY=4g
DOCKER_RUNNER_CPUS=2
DOCKER_RUNNER_TIMEOUT_S=1800

# ── 八点确认（已禁用）────────────────────────────────────────
# 当前默认不确认：agent 直接采用推荐默认值并继续导出。
# 保留重试上限仅作兜底：如果 agent 仍主动停下，自动 resume 最多几轮。
SKIP_EIGHT_CONFIRM_MAX=3
